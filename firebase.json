{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "firestore.rules",
      "firestore.indexes.json",
      "README.md",
      ".gitignore"
    ],
    "rewrites": [
      { "source": "/admin", "destination": "/admin-dashboard.html" }
    ],
    "headers": [
      {
        "source": "**/*.@(js|mjs)",
        "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
      }
    ]
  },
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  }
}
